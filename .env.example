# Affiliate program IDs — set these when approved for each network
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=verityaesthet-20
NEXT_PUBLIC_SEPHORA_AFF_ID=your-id

# Provider ingestion pipeline (scripts/ingest-providers.mjs)
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=

# Optional: OpenAI for AI Concierge live replies
OPENAI_API_KEY=

# Contact form (server-side only — never exposed to the browser)
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Inbox for contact form submissions
CONTACT_EMAIL=

# Optional verified sender for Resend (defaults to onboarding@resend.dev for testing)
# CONTACT_FROM=Verity Aesthetics <hello@verityaesthetics.app>
